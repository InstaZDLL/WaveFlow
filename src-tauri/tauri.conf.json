{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waveflow",
  "version": "0.1.0",
  "identifier": "app.waveflow",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "waveflow",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/waveflow/profiles/**",
          "$APPLOCALDATA/waveflow/profiles/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
