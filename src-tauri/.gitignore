# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Mobile icons emitted by `tauri icon` — desktop-only project, kept
# off-repo so the next icon refresh doesn't drag a few hundred
# unreferenced PNGs into the diff.
/icons/android/
/icons/ios/
