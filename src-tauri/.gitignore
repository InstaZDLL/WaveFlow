# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri build under `crates/app/`. The schemas are produced
# fresh on every build and have no business in the repo.
/crates/app/gen/schemas

# Mobile icons emitted by `tauri icon` — desktop-only project, kept
# off-repo so the next icon refresh doesn't drag a few hundred
# unreferenced PNGs into the diff.
/crates/app/icons/android/
/crates/app/icons/ios/
