# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
*.local

# Rust / Cargo (scoped ignore in src-tauri/.gitignore also applies)
target
**/*.rs.bk
*.pdb

# Generated by build.rs based on the `updater` Cargo feature.
# Lives in `crates/app/capabilities/` because tauri-build auto-discovers
# from there; the file is rewritten or removed on every build to match
# the feature flag, so it must never be committed.
src-tauri/crates/app/capabilities/updater.json

# TypeScript / bundler caches
*.tsbuildinfo
.eslintcache
.stylelintcache
.cache
.parcel-cache
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Test coverage
coverage
*.lcov

# Environment variables
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# AI related files
.agents/*
.claude/*
.mcp.json
skills-lock.json
.codex

# Local copies of release secrets (AUR SSH key, Tauri minisign key,
# Authenticode PFX). These feed the GitHub Actions secrets — never commit.
secrets/


#Ignore vscode AI rules
.github/instructions/codacy.instructions.md

# Codacy CLI machine-local artefacts. Only `.codacy/codacy.yaml`
# (tracked) and `.codacy/.gitignore` (untracked but versioned by
# convention) are part of the repo contract.
.codacy/cli.sh
.codacy/cli-config.yaml
.codacy/logs/
.codacy/tools-configs/

# Flatpak generator cache (Python venv + downloaded generators). The
# committed outputs in packaging/flatpak/generated/ are what Flathub
# consumes; this dir is local scratch and can be regenerated anytime.
packaging/flatpak/.cache/

# graphify knowledge-graph output (interactive HTML + GraphRAG JSON + per-file
# extraction cache). Machine-specific, fully regenerable from the cache.
graphify-out/
scripts/__pycache__/*
